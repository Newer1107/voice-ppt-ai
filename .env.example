# Application
APP_NAME="AI Lecture Narrator"
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-to-a-64-char-random-string

# Database
DATABASE_URL=postgresql+asyncpg://app_user:devpassword@localhost:5432/lecture_narrator
DB_PASSWORD=devpassword
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://:devpassword@localhost:6379/0
REDIS_RESULT_URL=redis://:devpassword@localhost:6379/1
REDIS_PASSWORD=devpassword

# JWT
JWT_SECRET_KEY=change-this-to-a-64-char-random-jwt-secret
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# AI Server — Unified GPU Service (single endpoint for all models)
# Runs on Machine B, exposes Whisper + BGE-M3 + vLLM/Qwen + F5-TTS
AI_SERVICE_URL=http://gpu-service:8001
AI_API_KEY=change-this-ai-api-key

# Storage — defaults to project-root/data/*.
# When running in Docker, set these to Docker volume mount paths:
#   STORAGE_ROOT=/data/storage
#   DATA_DIR=/data
STORAGE_BACKEND=local
STORAGE_ROOT=data/storage
VOICE_EMBEDDINGS_DIR=data/voice_embeddings

# Upload Limits
MAX_VIDEO_SIZE_BYTES=2147483648
MAX_AUDIO_SIZE_BYTES=524288000
MAX_PPTX_SIZE_BYTES=209715200

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Models
WHISPER_MODEL_SIZE=large-v3
VLLM_MODEL=Qwen/Qwen3-8B
TTS_SAMPLE_RATE=24000

# Hugging Face
HF_TOKEN=
